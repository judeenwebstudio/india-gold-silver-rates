# Copy this file to .env and replace the placeholders with your own local
# PostgreSQL credentials. Never commit the completed .env file.
# Runtime application connection. On Vercel + Supabase, use the transaction
# pooler URL (port 6543). Local PostgreSQL can keep the direct connection.
DATABASE_URL="postgresql://YOUR_USER:YOUR_PASSWORD@localhost:5432/india_gold_rates?schema=public"
# Optional migration connection. Use the Supabase direct or session-pooler URL.
DIRECT_URL="postgresql://YOUR_USER:YOUR_PASSWORD@localhost:5432/india_gold_rates?schema=public"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
AUTH_SECRET="replace-with-a-long-random-secret"
ADMIN_EMAIL="admin@indiagoldrates.local"
ADMIN_PASSWORD="replace-with-a-strong-password-of-at-least-12-characters"
RATE_SOURCE_NAME="IBJA"
RATE_SOURCE_URL="https://www.ibjarates.com/"
RATE_SOURCE_ENABLED="true"
SCRAPER_MAX_CHANGE_PERCENT="20"
SCRAPER_USER_AGENT="IndiaGoldSilverRates/1.0 (+http://localhost:3000/admin/api-logs)"
SCRAPER_REQUEST_TIMEOUT_MS="15000"
SCRAPER_MAX_RETRIES="2"
CRON_SECRET="replace-with-a-long-random-secret"
RATE_SYNC_TIMEZONE="Asia/Kolkata"
CITY_ADJUSTMENT_MAX_ABS="5000"
