generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt

  @@index([isActive, email])
}

enum MetalType {
  GOLD
  SILVER
}

enum MetalPurity {
  K24  @map("24K")
  K22  @map("22K")
  K18  @map("18K")
  K14  @map("14K")
  P999 @map("999")
  P925 @map("925")
}

enum RateUpdateStatus {
  SUCCESS
  FAILED
  REJECTED
}

enum RateHistoryAction {
  CREATE
  UPDATE
  SOFT_DELETE
}

model State {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  code      String   @unique
  isActive  Boolean  @default(true)
  cities    City[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, name])
}

model City {
  id                  String      @id @default(cuid())
  name                String
  slug                String      @unique
  stateId             String
  gold24KAdjustment   Decimal     @default(0) @db.Decimal(12, 4)
  gold22KAdjustment   Decimal     @default(0) @db.Decimal(12, 4)
  gold18KAdjustment   Decimal     @default(0) @db.Decimal(12, 4)
  gold14KAdjustment   Decimal     @default(0) @db.Decimal(12, 4)
  silver999Adjustment Decimal     @default(0) @db.Decimal(12, 4)
  isActive            Boolean     @default(true)
  deletedAt           DateTime?
  state               State       @relation(fields: [stateId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  metalRates          MetalRate[]
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@unique([stateId, name])
  @@index([stateId, isActive])
  @@index([isActive, name])
  @@index([isActive, deletedAt])
}

model MetalRate {
  id               String        @id @default(cuid())
  metalType        MetalType
  purity           MetalPurity
  pricePerGram     Decimal       @db.Decimal(14, 4)
  pricePerKilogram Decimal?      @db.Decimal(16, 2)
  cityId           String?
  city             City?         @relation(fields: [cityId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  source           String
  recordedAt       DateTime
  isActive         Boolean       @default(true)
  deletedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @default(now()) @updatedAt
  rateHistory      RateHistory[]

  @@index([metalType, purity, recordedAt])
  @@index([metalType, isActive, recordedAt])
  @@index([cityId, recordedAt])
  @@index([source, recordedAt])
  @@index([isActive, recordedAt])
  @@index([recordedAt])
}

model RateHistory {
  id           String            @id @default(cuid())
  metalRateId  String
  metalType    MetalType
  action       RateHistoryAction
  previousData Json?
  newData      Json?
  source       String            @default("ADMIN_UI")
  createdAt    DateTime          @default(now())
  metalRate    MetalRate         @relation(fields: [metalRateId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([metalRateId, createdAt])
  @@index([metalType, action, createdAt])
  @@index([createdAt])
}

model RateUpdateLog {
  id        String           @id @default(cuid())
  source    String
  sourceUrl String?
  status    RateUpdateStatus
  message   String
  rawData   Json?
  createdAt DateTime         @default(now())

  @@index([status, createdAt])
  @@index([source, createdAt])
  @@index([sourceUrl, createdAt])
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
